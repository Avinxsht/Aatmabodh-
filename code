  return (
    <div onClick={() => onClick(anime)} onMouseEnter={() => setHov(true)} onMouseLeave={() => setHov(false)}
      style={{ background:hov?C.cardHov:C.card, border:`1px solid ${hov?C.borderHov:C.border}`, borderRadius:10, overflow:"hidden", cursor:"pointer", transition:"all 0.2s ease", transform:hov?"translateY(-3px)":"none", boxShadow:hov?"0 12px 40px rgba(0,0,0,0.6)":"none" }}>
      <div style={{ position:"relative", aspectRatio:"2/3", overflow:"hidden" }}>
