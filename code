export default function App() {
  const [page, setPage] = useState("dashboard");
  const [detail, setDetail] = useState(null);
  const [sideOpen, setSideOpen] = useState(true);
  const [animeList, setAnimeList] = useState(BASE_ANIME);

  const updateProgress = useCallback((id, np) => {
    setAnimeList(prev => prev.map(a => {
      if (a.id !== id) return a;
      const finished = np >= a.episodes;
      return { ...a, myProgress:np, myStatus:finished?"Completed":a.myStatus==="Plan to Watch"?"Watching":a.myStatus, lastWatched:0 };
    }));
    setDetail(prev => {
      if (!prev||prev.id!==id) return prev;
      return { ...prev, myProgress:np, myStatus:np>=prev.episodes?"Completed":prev.myStatus };
    });
  }, []);

  const goTo = (pg) => { setPage(pg); setDetail(null); };

  return (
    <div style={{ display:"flex", minHeight:"100vh", background:C.bg, fontFamily:"'Outfit',sans-serif", color:C.text }}>
      <style>{`@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Outfit:wght@300;400;500;600;700&display=swap');*{box-sizing:border-box;margin:0;padding:0;}::-webkit-scrollbar{width:4px;height:4px;}::-webkit-scrollbar-track{background:transparent;}::-webkit-scrollbar-thumb{background:${C.border};border-radius:2px;}::-webkit-scrollbar-thumb:hover{background:${C.accent};}input::placeholder{color:${C.muted};}button{font-family:'Outfit',sans-serif;}`}</style>
      <Sidebar page={page} setPage={goTo} open={sideOpen} setOpen={setSideOpen}/>
      <main style={{ flex:1, overflowY:"auto", minWidth:0, maxHeight:"100vh" }}>
        {detail?(
          <DetailPage anime={detail} allAnime={animeList} onBack={()=>setDetail(null)} onSelect={a=>setDetail(a)} onUpdateProgress={updateProgress}/>
        ):page==="dashboard"?(
          <Dashboard animeList={animeList} onSelect={setDetail}/>
        ):page==="discover"?(
          <Discover animeList={animeList} onSelect={setDetail}/>
        ):page==="mylists"?(
          <MyLists animeList={animeList} onSelect={setDetail} onUpdateProgress={updateProgress}/>
        ):page==="blog"?(
          <Blog/>
        ):null}
      </main>
    </div>
  );
}
