function getSimilar(anime, all, limit = 5) {
  return all.filter(a => a.id !== anime.id).map(a => {
    let score = 0;
    const sg = a.genres.filter(g => anime.genres.includes(g)).length;
    const st = a.themes.filter(t => anime.themes.includes(t)).length;
    const sn = a.tone.filter(t => anime.tone.includes(t)).length;
    score += (sg / Math.max(anime.genres.length,1)) * 30;
    score += (st / Math.max(anime.themes.length,1)) * 25;
    score += (sn / Math.max(anime.tone.length,1)) * 20;
    if (a.studio === anime.studio) score += 15;
    score += Math.max(0, 10 - Math.abs(a.year - anime.year) * 1.5);
    let reason = "Similar style";
    if (sn > 0 && a.tone[0] === anime.tone[0]) reason = `Same ${a.tone[0].toLowerCase()} tone`;
    else if (a.studio === anime.studio) reason = "Same studio style";
    else if (st > 1) reason = "Psychological themes";
    else if (sg > 1) reason = "Similar power progression";
    return { ...a, _score: score, _reason: reason };
  }).sort((a,b) => b._score - a._score).slice(0, limit);
}

