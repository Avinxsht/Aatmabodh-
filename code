function Chip({ label, color=C.sec }) {
  return <span style={{ fontSize:10, fontWeight:600, letterSpacing:"0.04em", color, background:`${color}14`, border:`1px solid ${color}35`, borderRadius:4, padding:"2px 7px", whiteSpace:"nowrap" }}>{label}</span>;
}
function StatusPill({ s }) { return <Chip label={s} color={STATUS_COLOR[s]||C.sec} />; }
function Bar({ pct, color=C.accent, h=3 }) {
  return <div style={{ height:h, background:C.muted, borderRadius:h }}><div style={{ width:`${pct}%`, height:"100%", background:color, borderRadius:h, transition:"width 0.4s ease" }} /></div>;
}
function SectionHead({ title, sub, accent=C.accent }) {
  return (
    <div style={{ marginBottom:16 }}>
      <div style={{ display:"flex", alignItems:"center", gap:9 }}>
        <div style={{ width:3, height:16, background:accent, borderRadius:2, flexShrink:0 }} />
        <span style={{ fontSize:15, fontFamily:"'Syne',sans-serif", fontWeight:800, color:C.text }}>{title}</span>
      </div>
      {sub && <div style={{ fontSize:11, color:C.sec, marginLeft:12, marginTop:2 }}>{sub}</div>}
    </div>
  );
}

