          </div>
        </div>
        <div>
          <div style={{ fontSize:11, color:C.sec, marginBottom:5, fontStyle:"italic" }}>{anime.titleJP}</div>
          <h1 style={{ fontSize:30, fontFamily:"'Syne',sans-serif", fontWeight:800, color:C.text, lineHeight:1.1, marginBottom:14 }}>{anime.title}</h1>
          <div style={{ display:"flex", gap:7, flexWrap:"wrap", marginBottom:14 }}><StatusPill s={anime.myStatus}/><Chip label={`★ ${anime.rating}`} color={C.yellow}/></div>
          <div style={{ display:"flex", gap:5, flexWrap:"wrap", marginBottom:10 }}>{anime.genres.map(g=><Chip key={g} label={g} color={C.blue}/>)}</div>
          <div style={{ display:"flex", gap:5, flexWrap:"wrap", marginBottom:16 }}>{anime.themes.map(t=><Chip key={t} label={t} color={C.purple}/>)}</div>
